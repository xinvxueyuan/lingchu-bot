    "@types/d3-force": "^3.0.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "next-validate-link": "^1.6.6",
    "postcss": "^8.5.14",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
