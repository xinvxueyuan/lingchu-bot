    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "lint:links": "node --import tsx/esm scripts/lint.mts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fumadocs/language": "^0.0.1",
    "d3-force": "^3.0.0",
    "feed": "^5.2.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.9.0",
    "fumadocs-mdx": "15.0.7",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "16.9.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "tailwind-merge": "^3.6.0",
    "twoslash": "^0.3.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
