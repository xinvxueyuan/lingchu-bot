{
  "name": "docs",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "serve out",
    "check-types": "fumadocs-mdx && next typegen && fumadocs-mdx && tsc --noEmit",
    "types:check": "pnpm run check-types",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "lint:links": "node --import tsx/esm scripts/lint.mts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:hook": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fumadocs/language": "^0.0.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.4.11",
    "feed": "^5.2.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.9.3",
    "fumadocs-epub": "^1.1.0",
    "fumadocs-mdx": "15.0.11",
    "fumadocs-twoslash": "^3.2.1",
    "fumadocs-typescript": "^5.2.7",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-2d": "^1.29.1",
    "tailwind-merge": "^3.6.0",
    "twoslash": "^0.3.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-mdx": "^3.8.1",
    "jsdom": "^29.1.1",
    "next-validate-link": "^1.6.6",
    "postcss": "8.5.15",
    "remark-frontmatter": "^5.0.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
