# ── Docker build context exclusions ──────────────────────────────────────────
# Keeps the build context small and prevents secrets, caches, and
# non-runtime files from entering the image. Reviewed against the Dockerfile
# COPY instructions — everything needed by the builder or runtime is kept.

# ── Version control ──
.git
.gitignore
.gitattributes
.worktrees

# ── Python ──
.venv
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
dist/
MANIFEST

# ── Python caches / tooling ──
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.tox/
.nox/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.lcov

# ── Node.js ──
node_modules/
**/node_modules/
.npm
.eslintcache
*.tsbuildinfo

# ── Docs site build artifacts (not needed in the Python runtime image) ──
apps/docs/.next/
apps/docs/.source/
apps/docs/out/
apps/docs/.turbo/
apps/docs/playwright-report/
apps/docs/test-results/

# ── Turbo cache ──
.turbo/
**/.turbo/

# ── Environment files (keep examples for reference) ──
.env
.env.*
!.env.example
!.env.prod.example

# ── Tests (keep smoke tests for CI smoke-test image) ──
tests/*
!tests/smoke/
test-results/
playwright-report/

# ── Runtime data directories (created by localstore at runtime) ──
config/
data/
cache/
.local/

# ── Infrastructure directories (not needed in image) ──
.github/
.trae/
.gitnexus/
.agents/
.claude/
.superpowers/
.husky/
LICENSES/

# ── Documentation (not needed in runtime image) ──
*.md
apps/
packages/

# ── Docker files (not needed inside image) ──
Dockerfile
.dockerignore
docker-compose.yml

# ── IDE / OS ──
.idea/
.vscode/
*.code-workspace
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Misc ──
*.log
*.tmp
*.bak
REUSE.toml
Taskfile.yml
