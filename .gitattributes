* text=auto eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar.gz binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# Media
*.mp4  binary
*.mp3  binary
*.webm binary
*.ogg  binary

# Localization
*.po  text eol=lf
*.pot text eol=lf
*.mo  binary

# JSON5 config files — enforce LF line endings for cross-platform consistency
*.json5 text eol=lf

# Lock files — generated, exclude from language statistics
uv.lock          linguist-generated=true
pnpm-lock.yaml   linguist-generated=true
# Fumadocs generated source-of-truth collections
apps/docs/.source/ linguist-generated=true

# Exclude non-essential paths from release archives (git archive / dist tarball)
/.github/   export-ignore
/tests/     export-ignore
/.trae/     export-ignore
/.gitnexus/ export-ignore
/.turbo/    export-ignore
