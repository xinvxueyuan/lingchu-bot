{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  // 单一配置源：规则 + 检查范围 + 忽略目录
  // 所有调用方（Taskfile / husky / CI）均无参调用 markdownlint-cli2，由此文件统一驱动
  // 自动跟随根目录与子目录的 .gitignore，跳过生成物、缓存、工具私有目录和本地运行数据
  "gitignore": true,
  "config": {
    "default": true,
    "MD013": false, // 禁用行长度限制（CJK 内容不适用）
    "MD024": {
      "siblings_only": true, // 仅禁止同级重复标题（允许不同父节点下的同名标题）
    },
    "MD026": {
      "punctuation": ".,;:!", // 标题末尾禁止 .,;:! 标点
    },
    "MD033": false, // 允许内联 HTML（Callout / 章节标记等需要）
    "MD036": false, // 禁用强调作为标题检查（Callout / 提示框等需要）
    "MD041": false, // 不强制首行必须为一级标题
    "MD060": {
      "style": "consistent", // 标题末尾标点风格保持一致
    },
  },
  "globs": [
    "*.md", // 根目录所有 .md（AGENTS / CLAUDE / README / README-zh / CHANGELOG 等）
    "apps/**/*.md",
    "packages/**/*.md",
    ".github/**/*.md",
  ],
  "ignores": [
    // 防御性兜底：即使在没有 Git 元数据的源码归档中运行，也不扫描常见依赖和生成目录
    "**/node_modules/**",
    "**/out/**",
    "**/.venv/**",
    "**/.pytest_cache/**",
  ],
}
