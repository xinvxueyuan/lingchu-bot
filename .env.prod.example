# =============================================================================
# Lingchu Bot — Production Environment Template (docker compose)
# =============================================================================
# This is a docker compose production starting point. Copy to `.env.prod`
# (which is gitignored) and uncomment / adjust each value for your deployment.
# `docker-compose.yml` reads this file via `env_file: .env.prod`.
#
# All values mirror `.env.example` but are commented out by default. See
# `.env.example` for detailed inline documentation of each variable.
#
# Production-specific recommendations:
#   - IN_CONTAINERS=true              (running inside Docker)
#   - ALEMBIC_STARTUP_CHECK=true      (strict migration check on startup;
#                                      run `nb orm upgrade` manually before deploy)
#   - LOG_LEVEL=INFO                   (avoid DEBUG / TRACE in production)
#   - AI_API_KEY=<required for chat command>  (LLM features require a valid key)
#   - Disable FastAPI docs (set to empty or omit) to reduce attack surface
#   - Use a strong random value for SUPERUSER_KEY
#   - Use a real database URL (not the default SQLite) for persistence
# =============================================================================


# -----------------------------------------------------------------------------
# 1. NoneBot Core
# -----------------------------------------------------------------------------

# ENVIRONMENT=prod
# DRIVER=~fastapi+~httpx+~websockets
# HOST=0.0.0.0
# PORT=8080
# NICKNAME=lingchu
# SUPERUSERS=["123456789"]
# LOG_LEVEL=INFO
# COMMAND_START=["/", ""]
# COMMAND_SEP=[".", " "]
# FASTAPI_OPENAPI_URL=
# FASTAPI_DOCS_URL=
# FASTAPI_REDOC_URL=


# -----------------------------------------------------------------------------
# 2. Container Detection
# -----------------------------------------------------------------------------

# IN_CONTAINERS=true


# -----------------------------------------------------------------------------
# 3. Lingchu Runtime
# -----------------------------------------------------------------------------

# LINGCHU_SUPERUSERS={"user1":{"qq":"123456789"}}
# LINGCHU_ADAPTER=~onebot.v11
# LINGCHU_LOCALE=zh_CN
# SUPERUSER_KEY=<override-with-strong-random-value>


# -----------------------------------------------------------------------------
# 4. Localstore Paths
# -----------------------------------------------------------------------------

# LOCALSTORE_USE_CWD=true
# ANNOUNCEMENT_IMAGE_CACHE_DIR=/path/on/host/napcat-announcement-images
# ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu/announcement-images


# -----------------------------------------------------------------------------
# 5. Message Store
# -----------------------------------------------------------------------------

# MESSAGE_STORE_ENABLED=true
# MESSAGE_STORE_RETENTION_DAYS=30
# MESSAGE_STORE_SUMMARY_LIMIT=500
# MESSAGE_STORE_RECORD_API_CALLS=true
# MESSAGE_STORE_CLEANUP_ENABLED=true


# -----------------------------------------------------------------------------
# 6. Recall
# -----------------------------------------------------------------------------

# RECALL_MESSAGE_DEFAULT_COUNT=10


# -----------------------------------------------------------------------------
# 7. Permissions
# -----------------------------------------------------------------------------

# PERMISSION_PLATFORM_RUNTIME_PASSTHROUGH=true


# -----------------------------------------------------------------------------
# 8. Trigger Overrides
# -----------------------------------------------------------------------------

# COMMAND_TRIGGER_OVERRIDES=
# MENU_PAGE_TRIGGER_OVERRIDES=


# -----------------------------------------------------------------------------
# 9. Protected Subject Feature Keys
# -----------------------------------------------------------------------------

# PROTECTED_SUBJECT_FEATURE_KEYS=


# -----------------------------------------------------------------------------
# 10. Database
# -----------------------------------------------------------------------------

# ALEMBIC_STARTUP_CHECK=true
# SQLALCHEMY_DATABASE_URL=postgresql+psycopg://user:pass@db:5432/lingchu


# -----------------------------------------------------------------------------
# 11. LLM Service
# -----------------------------------------------------------------------------

# AI_PROVIDER=litellm
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=
# AI_TIMEOUT=60.0
# AI_API_KEY=<required for chat command>
