ENVIRONMENT=prod                          # 运行环境
HOST=0.0.0.0                              # 监听地址
PORT=8080                                 # 监听端口
SUPERUSERS=["12345789","987654321"]       # 控制台超级用户，拥有最大权限
LOCALSTORE_USE_CWD=true                   # 是否使用项目级存储(true为保存在项目目录，false为用户目录)
LOG_LEVEL=INFO                            # 日志级别
FASTAPI_OPENAPI_URL=/openapi.json         # OpenAPI schema
FASTAPI_DOCS_URL=/docs                    # Swagger UI(开发用途)
FASTAPI_REDOC_URL=/redoc                  # ReDoc 文档(开发用途)
