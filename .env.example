ENVIRONMENT=prod                          # 运行环境
HOST=0.0.0.0                              # 监听地址
PORT=8080                                 # 监听端口
LINGCHU_SUPERUSERS={"user1":{"qq":"12345789"},"root-alice":{"qq":"987654321","telegram":"alice"}} # Lingchu UID 到平台账号映射，拥有根级权限
SUPERUSERS=["12345789","987654321"]       # 兼容 fallback；LINGCHU_SUPERUSERS 缺失或为 null 时按 QQ 账号读取
# LOCALSTORE_USE_CWD controls where plugin data and config files are stored.
#   true  -> files are saved in the project directory (cwd).
#   false -> files are saved in the user's home directory.
# This affects both:
#   - config.json5   (runtime config, created by ensure_runtime_config_file)
#   - bot_state.json5 (bot state, created by load_bot_state)
LOCALSTORE_USE_CWD=true
LOG_LEVEL=INFO                            # 日志级别
FASTAPI_OPENAPI_URL=/openapi.json         # OpenAPI schema
FASTAPI_DOCS_URL=/docs                    # Swagger UI(开发用途)
FASTAPI_REDOC_URL=/redoc                  # ReDoc 文档(开发用途)
DRIVER=~fastapi+~httpx+~websockets        # 适配器驱动，使用空格分隔多个适配器，前缀 ~ 表示启用该适配器的默认配置
COMMAND_START=["/", ""]                   # 命令起始符，使用空格分隔多个起始符，空字符串表示无前缀
COMMAND_SEP=[".", " "]                    # 命令分隔符，使用空格分隔多个分隔符，空字符串表示无分隔符
# lingchu-bot i18n locale. Supported catalogs: zh_CN, en_US.
# LINGCHU_LOCALE=zh_CN

# Optional path bridge for OneBot V11 group announcement images when the
# protocol implementation reads images from a different filesystem, such as
# NapCat running in Docker while Lingchu Bot runs on the host (Windows,
# WSL2, or native Linux).
#
# ANNOUNCEMENT_IMAGE_CACHE_DIR must point to a directory visible to Lingchu
# Bot on its own host. ANNOUNCEMENT_IMAGE_PROTOCOL_DIR must point to the
# same directory as it is seen from inside the NapCat container (i.e. the
# bind-mount target). Use POSIX paths on Linux / WSL2 hosts; the style of
# ANNOUNCEMENT_IMAGE_PROTOCOL_DIR may follow the in-container view.
#
# See the NapCat Docker docs for the matching bind mount:
#   - English: https://lingchu.dev/docs/platforms/qq/frameworks/napcat-docker
#   - Chinese: https://lingchu.dev/zh/docs/platforms/qq/frameworks/napcat-docker
# ANNOUNCEMENT_IMAGE_CACHE_DIR=/path/on/host/napcat-announcement-images
# ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu/announcement-images
#
# WSL2 + Docker Desktop integration (recommended default for WSL2):
# 1) Add `\\wsl.localhost\Debian\` (or `\\wsl$\Debian\`) to Docker Desktop
#    Settings → Resources → File sharing, then Apply & restart.
# 2) From the WSL2 terminal run:
#    docker run -v /home/<user>/lingchu-bot:/lingchu-bot:ro mlikiowa/napcat-docker:latest
# 3) Keep paths POSIX; matching .env example:
# ANNOUNCEMENT_IMAGE_CACHE_DIR=/home/<user>/lingchu-bot/.local/napcat-announcement-images
# ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu-bot/.local/napcat-announcement-images
#
# See the NapCat Docker WSL2 deployment section for full steps and three
# supported topologies (Docker Desktop + WSL integration, UNC path workaround,
# native dockerd inside WSL2).

# Alembic startup check. Set to false in development to auto-sync schema on startup.
# In production, run `nb orm upgrade` manually and keep this set to true (default).
ALEMBIC_STARTUP_CHECK=false

# SQLAlchemy database URL for multi-database testing.
# When set, tests use the specified database backend instead of default SQLite.
# Examples:
#   postgresql+psycopg://postgres:postgres@localhost:5432/postgres
#   mysql+aiomysql://mysql:mysql@localhost:3306/mymysql
#   mysql+aiomysql://mariadb:mariadb@localhost:3306/mymariadb  (SQLAlchemy auto-detects MariaDB via SELECT VERSION())
#   oracle+oracledb://system:oracle@localhost:1521/?service_name=FREEPDB1
#   mssql+aioodbc://sa:Password!1@localhost:1433/master?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# Leave unset to use the default SQLite database.
# SQLALCHEMY_DATABASE_URL=
