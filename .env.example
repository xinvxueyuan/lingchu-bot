# =============================================================================
# Lingchu Bot — Environment Configuration Example
# =============================================================================
# Copy this file to `.env` and adjust values for your deployment.
# Every variable below is read by either:
#   - NoneBot2 core (HOST / PORT / DRIVER / SUPERUSERS / ...)
#   - nonebot_plugin_localstore (LOCALSTORE_USE_CWD)
#   - nonebot_plugin_orm (ALEMBIC_STARTUP_CHECK / SQLALCHEMY_DATABASE_URL)
#   - src/plugins/nonebot_plugin_lingchu_bot/core/config.py
#   - src/plugins/nonebot_plugin_lingchu_bot/core/runtime_config.py
#   - src/plugins/nonebot_plugin_lingchu_bot/i18n/__init__.py (LINGCHU_LOCALE)
# Inline comments reference the source field name that consumes each var.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. NoneBot Core
# Refs: nonebot.config.Config (NoneBot2 global config)
# -----------------------------------------------------------------------------

# NoneBot2 environment selection. "prod" loads .env, "dev" loads .env.dev,
# "test" loads .env.test.
ENVIRONMENT=prod                              # nonebot.config.Config.environment

# Driver selection. `~` prefix activates default config for each driver.
DRIVER=~fastapi+~httpx+~websockets           # nonebot.config.Config.driver

# FastAPI server bind address and port.
HOST=0.0.0.0                                 # nonebot.config.Config.host
PORT=8080                                    # nonebot.config.Config.port

# Bot nickname(s). First entry becomes the primary nickname.
NICKNAME=lingchu                             # nonebot.config.Config.nickname

# NoneBot2 superuser list. Used as fallback when LINGCHU_SUPERUSERS is null.
SUPERUSERS=["123456789"]                      # nonebot.config.Config.superusers

# Logging level. One of: TRACE / DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO                               # nonebot.config.Config.log_level

# Command prefix characters. Empty string allows no-prefix commands.
COMMAND_START=["/", ""]                       # nonebot.config.Config.command_start

# Command argument separators.
COMMAND_SEP=[".", " "]                        # nonebot.config.Config.command_sep

# FastAPI OpenAPI / Swagger / ReDoc endpoints. Set to empty for production.
FASTAPI_OPENAPI_URL=/openapi.json            # nonebot.config.Config.fast_api_openapi_url
FASTAPI_DOCS_URL=/docs                        # nonebot.config.Config.fast_api_docs_url
FASTAPI_REDOC_URL=/redoc                      # nonebot.config.Config.fast_api_redoc_url


# -----------------------------------------------------------------------------
# 2. Container Detection
# Refs: core/config.py::Config.in_containers
# -----------------------------------------------------------------------------

# Set to true when running inside Docker / Kubernetes. MUST be lowercase
# true/false — NoneBot2 only accepts JSON-standard booleans here.
LINGCHU_IN_CONTAINERS=false                  # core/config.py::Config.in_containers


# -----------------------------------------------------------------------------
# 3. Lingchu Runtime
# Refs: core/runtime_config.py::RuntimeConfig
# -----------------------------------------------------------------------------

# Structured superuser mapping: { "lingchu_uid": { "platform_id": "account_id" } }.
# JSON5 syntax supported. Lingchu UID grants root-level permissions across
# the configured platform accounts.
LINGCHU_SUPERUSERS={"user1":{"qq":"123456789"}}  # RuntimeConfig.lingchu_superusers

# Adapter selection. Use `~` prefix to use NoneBot adapter shorthand.
LINGCHU_ADAPTER=~onebot.v11                  # RuntimeConfig.lingchu_adapter

# lingchu-bot i18n locale. Supported catalogs: zh_CN, en_US.
# Accepts LINGCHU_LOCALE / LC_LOCALE / LOCALE (first non-empty wins).
LINGCHU_LOCALE=zh_CN                         # i18n.__init__._read_configured_locale (lingchu_locale)

# Lightweight auth key used for root-level operations when no Lingchu
# superuser is configured. Override in production with a strong random value.
LINGCHU_SUPERUSER_KEY=123456789abcdef         # RuntimeConfig.superuser_key


# -----------------------------------------------------------------------------
# 4. Localstore Paths
# Refs: nonebot_plugin_localstore (LOCALSTORE_USE_CWD),
#       core/config.py::Config.announcement_image_*
# -----------------------------------------------------------------------------

# Where nonebot_plugin_localstore stores plugin data / config / cache.
# true  -> project cwd (recommended for development)
# false -> user home directory
LOCALSTORE_USE_CWD=true                      # nonebot_plugin_localstore::LOCALSTORE_USE_CWD

# Host-side cache directory for group announcement images.
# Default: <localstore cache_dir>/announcement_images.
# Override only for cross-container file sharing (e.g. NapCat bind mount).
# LINGCHU_ANNOUNCEMENT_IMAGE_CACHE_DIR=/path/on/host/napcat-announcement-images
#                                            # core/config.py::Config.announcement_image_cache_dir

# Protocol-side path: container-internal path seen by NapCat.
# Required when LINGCHU_ANNOUNCEMENT_IMAGE_CACHE_DIR is set and NapCat runs in Docker.
# LINGCHU_ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu/announcement-images
#                                            # core/config.py::Config.announcement_image_protocol_dir

# -----------------------------------------------------------------------------
# NapCat WSL2 + Docker Desktop announcement-image guidance
# -----------------------------------------------------------------------------
# Optional path bridge for OneBot V11 group announcement images when the
# protocol implementation reads images from a different filesystem, such as
# NapCat running in Docker while Lingchu Bot runs on the host (Windows,
# WSL2, or native Linux).
#
# LINGCHU_ANNOUNCEMENT_IMAGE_CACHE_DIR must point to a directory visible to Lingchu
# Bot on its own host. LINGCHU_ANNOUNCEMENT_IMAGE_PROTOCOL_DIR must point to the
# same directory as it is seen from inside the NapCat container (i.e. the
# bind-mount target). Use POSIX paths on Linux / WSL2 hosts; the style of
# LINGCHU_ANNOUNCEMENT_IMAGE_PROTOCOL_DIR may follow the in-container view.
#
# See the NapCat Docker docs for the matching bind mount:
#   - English: https://lingchu.dev/docs/platforms/qq/frameworks/napcat-docker
#   - Chinese: https://lingchu.dev/zh/docs/platforms/qq/frameworks/napcat-docker
#
# WSL2 + Docker Desktop integration (recommended default for WSL2):
# 1) Add `\\wsl.localhost\Debian\` (or `\\wsl$\Debian\`) to Docker Desktop
#    Settings → Resources → File sharing, then Apply & restart.
# 2) From the WSL2 terminal run:
#    docker run -v /home/<user>/lingchu-bot:/lingchu-bot:ro mlikiowa/napcat-docker:latest
# 3) Keep paths POSIX; matching .env example:
# LINGCHU_ANNOUNCEMENT_IMAGE_CACHE_DIR=/home/<user>/lingchu-bot/.local/napcat-announcement-images
# LINGCHU_ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu-bot/.local/napcat-announcement-images
#
# See the NapCat Docker WSL2 deployment section for full steps and three
# supported topologies (Docker Desktop + WSL integration, UNC path workaround,
# native dockerd inside WSL2).


# -----------------------------------------------------------------------------
# 5. Message Store
# Refs: core/runtime_config.py::RuntimeConfig.message_store_*
# -----------------------------------------------------------------------------

# Enable message storage hooks (group message history, audit, summary).
LINGCHU_MESSAGE_STORE_ENABLED=true            # RuntimeConfig.message_store_enabled

# Days to retain stored messages. 0 = unlimited.
LINGCHU_MESSAGE_STORE_RETENTION_DAYS=30      # RuntimeConfig.message_store_retention_days

# Maximum number of messages included in a single summary.
LINGCHU_MESSAGE_STORE_SUMMARY_LIMIT=500      # RuntimeConfig.message_store_summary_limit

# Whether platform API call summaries are recorded.
LINGCHU_MESSAGE_STORE_RECORD_API_CALLS=true  # RuntimeConfig.message_store_record_api_calls

# Enable automatic cleanup of expired message records.
LINGCHU_MESSAGE_STORE_CLEANUP_ENABLED=true   # RuntimeConfig.message_store_cleanup_enabled


# -----------------------------------------------------------------------------
# 6. Recall
# Refs: core/runtime_config.py::RuntimeConfig.recall_message_default_count
# -----------------------------------------------------------------------------

# Default number of messages to recall when no explicit count is given.
# Range: 1–100.
LINGCHU_RECALL_MESSAGE_DEFAULT_COUNT=10       # RuntimeConfig.recall_message_default_count


# -----------------------------------------------------------------------------
# 7. Permissions
# Refs: core/runtime_config.py::RuntimeConfig.permission_platform_runtime_passthrough
# -----------------------------------------------------------------------------

# Whether platform permission resolvers pass through to runtime config.
# true = passthrough; false = strict; or per-platform mapping (JSON5).
LINGCHU_PERMISSION_PLATFORM_RUNTIME_PASSTHROUGH=true # RuntimeConfig.permission_platform_runtime_passthrough


# -----------------------------------------------------------------------------
# 8. Trigger Overrides
# Refs: core/runtime_config.py::RuntimeConfig.{command,menu_page}_trigger_overrides
# -----------------------------------------------------------------------------

# Per-command trigger word overrides (JSON5). Empty = use defaults.
# Example: {"kick_member":{"triggers":["kick","踢"]}}
# LINGCHU_COMMAND_TRIGGER_OVERRIDES=                  # RuntimeConfig.command_trigger_overrides

# Per-menu-page trigger overrides (JSON5). Empty = use defaults.
# LINGCHU_MENU_PAGE_TRIGGER_OVERRIDES=                # RuntimeConfig.menu_page_trigger_overrides


# -----------------------------------------------------------------------------
# 9. Protected Subject Feature Keys
# Refs: core/runtime_config.py::RuntimeConfig.protected_subject_feature_keys
# -----------------------------------------------------------------------------

# Feature keys that require elevated subject permission. JSON5 list of strings.
# Defaults to a built-in set of sensitive operations (kick / block / mute / etc.).
# LINGCHU_PROTECTED_SUBJECT_FEATURE_KEYS=             # RuntimeConfig.protected_subject_feature_keys


# -----------------------------------------------------------------------------
# 10. Database
# Refs: nonebot_plugin_orm (ALEMBIC_STARTUP_CHECK, SQLALCHEMY_DATABASE_URL)
# -----------------------------------------------------------------------------

# Run Alembic migration check on startup.
# true  = strict (production; run `nb orm upgrade` manually)
# false = auto-sync schema on startup (development)
ALEMBIC_STARTUP_CHECK=false                  # nonebot_plugin_orm startup check

# SQLAlchemy database URL. Supports six backends: SQLite (default), PostgreSQL,
# MySQL, MariaDB, Oracle, SQL Server. Leave unset for default SQLite.
# Examples:
#   postgresql+psycopg://postgres:postgres@localhost:5432/postgres
#   mysql+aiomysql://mysql:mysql@localhost:3306/mymysql
#   mysql+aiomysql://mariadb:mariadb@localhost:3306/mymariadb  (SQLAlchemy auto-detects MariaDB via SELECT VERSION())
#   oracle+oracledb://system:oracle@localhost:1521/?service_name=FREEPDB1
#   mssql+aioodbc://sa:Password!1@localhost:1433/master?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# SQLALCHEMY_DATABASE_URL=                   # nonebot_plugin_orm / tests/conftest.py


# -----------------------------------------------------------------------------
# 11. LLM Service
# Refs: core/runtime_config.py::RuntimeConfig.ai_*
# -----------------------------------------------------------------------------

# LLM provider backend. One of: litellm, openai.
LINGCHU_AI_PROVIDER=litellm                   # RuntimeConfig.ai_provider

# Default LLM model name.
LINGCHU_AI_MODEL=gpt-4o-mini                 # RuntimeConfig.ai_model

# Optional OpenAI-compatible base URL (for DeepSeek, Qwen, Moonshot, Zhipu,
# OpenRouter, Ollama, etc.). Leave unset for OpenAI default.
# LINGCHU_AI_BASE_URL=                               # RuntimeConfig.ai_base_url

# Request timeout in seconds.
LINGCHU_AI_TIMEOUT=60.0                      # RuntimeConfig.ai_timeout

# LLM API key. Required for the chat handle and AI schedule features.
# When left empty/unset, the underlying SDK falls back to the OPENAI_API_KEY
# environment variable. For OpenAI-compatible endpoints, set this to your
# vendor key.
# LINGCHU_AI_API_KEY=                                # RuntimeConfig.ai_api_key
