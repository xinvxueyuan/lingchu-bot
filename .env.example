ENVIRONMENT=prod                          # 运行环境
HOST=0.0.0.0                              # 监听地址
PORT=8080                                 # 监听端口
LINGCHU_SUPERUSERS={"user1":{"qq":"12345789"},"root-alice":{"qq":"987654321","telegram":"alice"}} # Lingchu UID 到平台账号映射，拥有根级权限
SUPERUSERS=["12345789","987654321"]       # 兼容 fallback；LINGCHU_SUPERUSERS 缺失或为 null 时按 QQ 账号读取
# LOCALSTORE_USE_CWD controls where plugin data and config files are stored.
#   true  -> files are saved in the project directory (cwd).
#   false -> files are saved in the user's home directory.
# This affects both:
#   - config.json5   (runtime config, created by ensure_runtime_config_file)
#   - bot_state.json5 (bot state, created by load_bot_state)
LOCALSTORE_USE_CWD=true
LOG_LEVEL=INFO                            # 日志级别
FASTAPI_OPENAPI_URL=/openapi.json         # OpenAPI schema
FASTAPI_DOCS_URL=/docs                    # Swagger UI(开发用途)
FASTAPI_REDOC_URL=/redoc                  # ReDoc 文档(开发用途)
DRIVER=~fastapi+~httpx+~websockets        # 适配器驱动，使用空格分隔多个适配器，前缀 ~ 表示启用该适配器的默认配置
COMMAND_START=["/", ""]                   # 命令起始符，使用空格分隔多个起始符，空字符串表示无前缀
COMMAND_SEP=[".", " "]                    # 命令分隔符，使用空格分隔多个分隔符，空字符串表示无分隔符
# lingchu-bot i18n locale. Supported catalogs: zh_CN, en_US.
# LINGCHU_LOCALE=zh_CN

# Optional path bridge for OneBot V11 group announcement images when the
# protocol implementation reads images from a different filesystem, such as
# NapCat running in Docker Desktop while Lingchu Bot runs on Windows.
# ANNOUNCEMENT_IMAGE_CACHE_DIR=C:/dev/lingchu-bot/.local/napcat-announcement-images
# ANNOUNCEMENT_IMAGE_PROTOCOL_DIR=/lingchu/announcement-images

# Alembic startup check. Set to false in development to auto-sync schema on startup.
# In production, run `nb orm upgrade` manually and keep this set to true (default).
ALEMBIC_STARTUP_CHECK=false

# SQLAlchemy database URL for multi-database testing.
# When set, tests use the specified database backend instead of default SQLite.
# Examples:
#   postgresql+psycopg://postgres:postgres@localhost:5432/postgres
#   mysql+aiomysql://mysql:mysql@localhost:3306/mymysql
# Leave unset to use the default SQLite database.
# SQLALCHEMY_DATABASE_URL=
