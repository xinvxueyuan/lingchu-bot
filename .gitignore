# Created by https://www.toptal.com/developers/gitignore/api/python
# Edit at https://www.toptal.com/developers/gitignore?templates=python
# Cleaned for lingchu-bot: NoneBot2 + uv + pnpm + Turborepo + Next.js + Fumadocs.
# Project does NOT use: Django, Flask, Scrapy, Sphinx, zensical, PyBuilder,
# Jupyter, IPython, pyenv, pipenv, PEP 582, Celery, SageMath, Spyder, Rope,
# mkdocs, Pyre, pytype, PDM, PyInstaller. Remove their entries when re-applying
# the upstream template.
#
# IMPORTANT: Git does NOT support inline comments. Trailing text after a
# pattern (e.g. `.venv  # comment`) is treated as part of the glob and the
# rule becomes inert. Keep each comment on its own line.

# ===== Monorepo / build tooling =====
# Turborepo daemon logs and per-package cache
.turbo/
# git worktree checkouts
.worktrees/
# uv cache (uv sync / uv tool default location)
.uv-cache/
# GitNexus-managed Codex skill copies (synchronized by the tool).
# `.claude/skills` and `.trae/skills` are whole-directory symlinks to
# `.agents/skills/`, so this single entry also covers them via symlink resolution.
.agents/skills/gitnexus/

# ===== Python =====
# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
# C extensions
*.so
# Environments
.env
.env.*
!.env.example
!.env.prod.example
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
# Distribution / packaging artifacts
.Python
build/
dist/
*.egg-info/
*.egg
.installed.cfg
# Type checkers / linters used by the project
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.ruff_cache/
.uv-python
uv.toml

# ===== Test & coverage =====
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml
# nonebot-plugin-localstore pytest fixture data
.pytest-localstore/
# Playwright root-level artifacts
playwright-report/
test-results/

# ===== Apps / docs (Next.js + Fumadocs) =====
# Root /docs/ is intentionally ignored; canonical docs live in apps/docs/.
/docs
.source/
apps/docs/.source/
apps/docs/.next/
apps/docs/out/
apps/docs/coverage/
apps/docs/playwright-report/
apps/docs/test-results/
apps/docs/next-env.d.ts
apps/docs/.eslintcache
# Codex dev server logs (both with and without .err/.out suffix)
apps/docs/.codex-dev-server.log
apps/docs/.codex-dev-server.*.log
*.log
*.tsbuildinfo
coverage/

# ===== Local runtime (nonebot-plugin-localstore / nonebot-plugin-orm) =====
data/
config/
tmp/
cache/

# ===== Lockfile policy =====
# uv.lock is tracked (single source of truth, project uses uv).
# pnpm-lock.yaml is tracked (single source of truth, project uses pnpm).
# Project does not use poetry / Pipfile / pdm; no lockfiles for them to ignore.

# ===== IDE / Editor =====
# JetBrains / PyCharm
.idea/
# VS Code — ignore user settings, keep project-level extensions and MCP
.vscode/*
!.vscode/extensions.json
!.vscode/mcp.json
*.code-workspace

# ===== Tooling indexes / agent caches =====
# GitNexus knowledge graph (rebuilt by `npx gitnexus analyze`)
.gitnexus/
# CodeGraph daemon data
.codegraph/
# OpenAI Codex CLI local cache
.codex/
# Firecrawl MCP runtime cache
.firecrawl/
# Superpowers plan / spec cache
.superpowers/
# AstrBot private skills (CLI --all byproduct; project does not use AstrBot)
agent/
# nonebot CLI local data
.local/

# ===== pnpm =====
node_modules/

# End of https://www.toptal.com/developers/gitignore/api/python
