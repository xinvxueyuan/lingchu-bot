#!/usr/bin/env sh
# POSIX-compliant shell; invoked via .husky/_/h with `sh -e` (shebang is informational)

# Pre-commit hook: 自动修复 → 快速检查 → 慢速检查 → 非阻断分析
# 原则：快反馈优先，阻断性检查在前，非阻断分析放最后
#
# 模块化结构（v4 — husky pre-commit 模块化拆分）：
#   - .husky/lib/detect.sh    工具解析 + 一次性探测 + 暂存文件类型检测
#   - .husky/lib/markdown.sh  Phase 2:   markdownlint
#   - .husky/lib/python.sh    Phase 2.5: # noqa 防回退 | Phase 4: Pyright | Phase 5: pytest
#   - .husky/lib/frontend.sh  Phase 6a-6d: ESLint/check-types/Vitest/Playwright | Phase 7: React Doctor
#
# 与 prek 的职责划分（避免重复执行）：
#   - prek.toml（Phase 1 调用）负责: trailing-whitespace, end-of-file-fixer,
#     check-yaml/toml/json/xml, check-merge-conflict, check-added-large-files,
#     detect-private-key, check-case-conflict, mixed-line-ending, check-symlinks,
#     destroyed-symlinks, ruff (--fix), ruff-format, ty
#   - husky pre-commit 负责: markdownlint, # noqa 防回退, Pyright, pytest,
#     ESLint, turbo check-types, Docs Vitest, Docs Playwright, React Doctor,
#     Gitnexus 非阻断分析
#   - 已移除的重复检查: Phase 3 (Ruff lint + Ruff format) 与 Phase 4 中的 ty
set +e

# ── 定位 husky 目录（兼容 symlink、subshell、不同启动路径）──────────
# .husky/_/h 以 sh -e 调用本脚本；$0 可能是相对路径或绝对路径。
HUSKY_DIR=$(dirname "$0")
case "$HUSKY_DIR" in
    /*) ;;                          # 绝对路径，直接使用
    *)  HUSKY_DIR="$PWD/$HUSKY_DIR" ;; # 相对路径，补全为绝对路径
esac
# 解析可能存在的 .. 或 . 段（不依赖 readlink，保持 POSIX）
HUSKY_DIR=$(cd "$HUSKY_DIR" && pwd)
LIB_DIR="$HUSKY_DIR/lib"

# ── source 库模块（顺序敏感：detect.sh 必须最先）────────────────────
# detect.sh 提供工具解析函数、环境探测、HAS_*/NEEDS_* 标志，
# 后续 markdown.sh / python.sh / frontend.sh 均依赖这些变量与函数。
if [ ! -f "$LIB_DIR/detect.sh" ]; then
    echo "❌ 缺少 $LIB_DIR/detect.sh，husky 模块化拆分不完整。"
    exit 1
fi
# shellcheck disable=SC1090
. "$LIB_DIR/detect.sh"
# shellcheck disable=SC1090
. "$LIB_DIR/markdown.sh"
# shellcheck disable=SC1090
. "$LIB_DIR/python.sh"
# shellcheck disable=SC1090
. "$LIB_DIR/frontend.sh"

echo "🚀 正在运行代码检查..."

# ── Phase 1: 自动修复（prek 始终运行，prek 自身按 stage 过滤）────────
# prek 在此统一处理: ruff (--fix) + ruff-format + ty + 通用文件检查钩子
# husky 不再在后续 phase 重复运行 ruff/ty，避免双重执行。
if [ -n "$UV_CMD" ]; then
    echo "🔧 正在运行 Prek 自动修复..."
    if command -v task >/dev/null 2>&1; then
        task hooks:staged
    else
        "$UV_CMD" run prek validate-config prek.toml &&
            "$UV_CMD" run prek run --config prek.toml --stage pre-commit
    fi
    if [ $? -ne 0 ]; then
        echo "ℹ️  Prek 需要重新暂存自动修复或 hook 配置变更，正在暂存并重试..."
        "$GIT_CMD" add -u
        if command -v task >/dev/null 2>&1; then
            task hooks:staged
        else
            "$UV_CMD" run prek validate-config prek.toml &&
                "$UV_CMD" run prek run --config prek.toml --stage pre-commit
        fi
        if [ $? -ne 0 ]; then
            echo "❌ Prek 检查失败，请修复后重新提交。"
            exit 1
        fi
    fi
else
    echo "⚠️  未找到 uv，跳过 Prek 检查。"
fi

# ── Phase 2: Markdownlint（秒级，.md 变更触发）──────────────────────
run_markdown_checks

# ── Phase 2.5 + Phase 4 + Phase 5: Python 检查 ──────────────────────
# Phase 2.5: # noqa 防回退（非阻断告警）
# Phase 4:   Pyright 类型检查（ty 已由 prek 在 Phase 1 处理）
# Phase 5:   pytest 测试
# 注：Phase 3 (Ruff lint + Ruff format) 已移除，由 prek 接管
run_python_checks

# ── Phase 6a-6d + Phase 7: 前端检查 ─────────────────────────────────
# Phase 6a: ESLint | Phase 6b: turbo check-types | Phase 6c: Docs Vitest
# Phase 6d: Docs Playwright Chromium 冒烟 | Phase 7: React Doctor
run_frontend_checks

echo "✅ 所有检查通过！"

# Gitnexus 分析已移至 post-commit 钩子，避免索引落后一个提交
