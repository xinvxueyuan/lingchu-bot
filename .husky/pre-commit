#!/usr/bin/env bash

# Pre-commit hook: 自动修复 → 快速检查 → 慢速检查 → 非阻断分析
# 原则：快反馈优先，阻断性检查在前，非阻断分析放最后
# 优化：仅当变更文件命中检查范围时才执行对应检查，缩短无关注变更的提交耗时
set +e

# first_runnable <command>... — 返回第一个可执行且能启动的命令
first_runnable() {
    for candidate in "$@"; do
        if command -v "$candidate" >/dev/null 2>&1 && "$candidate" --version >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

# first_cmd_runnable <command.cmd>... — 返回第一个可通过 cmd.exe 启动的 Windows 命令
first_cmd_runnable() {
    if ! command -v cmd.exe >/dev/null 2>&1; then
        return 1
    fi
    for candidate in "$@"; do
        if command -v "$candidate" >/dev/null 2>&1 && cmd.exe /c "$candidate" --version >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

select_js_runner() {
    native_cmd=$(first_runnable "$1" "$1.exe")
    if [ -n "$native_cmd" ]; then
        printf 'native:%s\n' "$native_cmd"
        return 0
    fi

    cmd_tool=$(first_cmd_runnable "$1.cmd")
    if [ -n "$cmd_tool" ]; then
        printf 'cmd:%s\n' "$cmd_tool"
        return 0
    fi

    return 1
}

run_pnpm() {
    case "$PNPM_RUNNER" in
        native:*) "${PNPM_RUNNER#native:}" "$@" ;;
        cmd:*) cmd.exe /c "${PNPM_RUNNER#cmd:}" "$@" ;;
        *) return 127 ;;
    esac
}

run_npx() {
    case "$NPX_RUNNER" in
        native:*) "${NPX_RUNNER#native:}" "$@" ;;
        cmd:*) cmd.exe /c "${NPX_RUNNER#cmd:}" "$@" ;;
        *) return 127 ;;
    esac
}

GIT_CMD=$(first_runnable git git.exe)
UV_CMD=$(first_runnable uv uv.exe)
PNPM_RUNNER=$(select_js_runner pnpm)
NPX_RUNNER=$(select_js_runner npx)

if [ -z "$GIT_CMD" ]; then
    echo "❌ 未找到可运行的 git，无法检测暂存区变更。"
    exit 1
fi

# ── 变更检测 ────────────────────────────────────────────
# 收集暂存区变更文件列表（含重命名目标），用于按需触发检查

STAGED_FILES=$("$GIT_CMD" diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

# has_pattern <glob_pattern>... — 任一模式匹配到暂存文件则返回 0
has_pattern() {
    for pattern in "$@"; do
        if printf '%s\n' "$STAGED_FILES" | grep -qE "$pattern"; then
            return 0
        fi
    done
    return 1
}

# 检测各领域是否有变更
HAS_PYTHON=false
HAS_PY_CONFIG=false   # pyproject.toml / ruff.toml / uv.lock 等 Python 配置
HAS_DOCS=false        # apps/docs/ 下的前端/文档变更

if has_pattern '\.py$'; then
    HAS_PYTHON=true
fi
if has_pattern '(^|/)(pyproject\.toml|ruff\.toml|\.ruff\.toml|uv\.lock|\.python-version)$'; then
    HAS_PY_CONFIG=true
fi
if has_pattern '^apps/docs/.*\.(ts|tsx|css|mdx|mjs|json)$'; then
    HAS_DOCS=true
fi
# docs 配置文件变更也触发
if has_pattern '^apps/docs/(next\.config\.mjs|source\.config\.ts|tsconfig\.json|vitest\.config\.ts|eslint\.config\.mjs|postcss\.config\.mjs|package\.json)$'; then
    HAS_DOCS=true
fi

# Python 相关检查：.py 文件或 Python 配置变更时触发
NEEDS_PYTHON_CHECK=false
if [ "$HAS_PYTHON" = true ] || [ "$HAS_PY_CONFIG" = true ]; then
    NEEDS_PYTHON_CHECK=true
fi

echo "🚀 正在运行代码检查..."

# ── Phase 1: 自动修复 ──────────────────────────────────

# Prek: lint/format 自动修复 + 重新暂存（始终运行，prek 自身按 stage 过滤）
if [ -n "$UV_CMD" ]; then
    echo "🔧 正在运行 Prek 自动修复..."
    "$UV_CMD" run prek run --config prek.toml --stage pre-commit
    if [ $? -ne 0 ]; then
        echo "ℹ️  Prek 自动修复了部分文件，正在重新暂存..."
        "$GIT_CMD" add -u
    fi
else
    echo "⚠️  未找到 uv，跳过 Prek 检查。"
fi

# ── Phase 2: 快速检查（秒级）──────────────────────────

if [ "$NEEDS_PYTHON_CHECK" = true ]; then
    # Ruff lint
    if [ -n "$UV_CMD" ]; then
        echo "🔍 正在运行 Ruff lint..."
        "$UV_CMD" run -m ruff check . --output-format=github
        if [ $? -ne 0 ]; then
            echo "❌ Ruff lint 检查失败，请修复后重新提交。"
            exit 1
        fi
    fi

    # Ruff format
    if [ -n "$UV_CMD" ]; then
        echo "🔍 正在运行 Ruff format 检查..."
        "$UV_CMD" run -m ruff format --check .
        if [ $? -ne 0 ]; then
            echo "❌ Ruff format 检查失败，请运行 'task format' 后重新提交。"
            exit 1
        fi
    fi
else
    echo "⏭️  无 Python 变更，跳过 Ruff lint/format 检查。"
fi

# ── Phase 3: 类型检查（十秒级）────────────────────────

if [ "$NEEDS_PYTHON_CHECK" = true ]; then
    # Pyright
    if [ -n "$UV_CMD" ]; then
        echo "🔍 正在运行 Pyright 类型检查..."
        "$UV_CMD" run -m pyright .
        if [ $? -ne 0 ]; then
            echo "❌ Pyright 类型检查失败，请修复后重新提交。"
            exit 1
        fi
    fi

    # ty
    if [ -n "$UV_CMD" ]; then
        echo "🔍 正在运行 ty 类型检查..."
        "$UV_CMD" run -m ty check --output-format github
        if [ $? -ne 0 ]; then
            echo "❌ ty 类型检查失败，请修复后重新提交。"
            exit 1
        fi
    fi
else
    echo "⏭️  无 Python 变更，跳过 Pyright/ty 类型检查。"
fi

# ── Phase 4: 测试（十秒级）────────────────────────────

if [ "$NEEDS_PYTHON_CHECK" = true ]; then
    # pytest
    if [ -n "$UV_CMD" ]; then
        echo "🧪 正在运行 pytest..."
        "$UV_CMD" run -m pytest -x -q
        if [ $? -ne 0 ]; then
            echo "❌ pytest 测试失败，请修复后重新提交。"
            exit 1
        fi
    fi
else
    echo "⏭️  无 Python 变更，跳过 pytest 测试。"
fi

# ── Phase 5: Docs 检查（十秒级）────────────────────────

if [ "$HAS_DOCS" = true ]; then
    # Docs ESLint
    if [ -n "$PNPM_RUNNER" ]; then
        echo "🔍 正在运行 Docs ESLint..."
        run_pnpm --filter docs lint
        if [ $? -ne 0 ]; then
            echo "❌ Docs ESLint 检查失败，请修复后重新提交。"
            exit 1
        fi
    fi

    # Docs Type Check
    if [ -n "$PNPM_RUNNER" ]; then
        echo "🔍 正在运行 Docs 类型检查..."
        run_pnpm --filter docs check-types
        if [ $? -ne 0 ]; then
            echo "❌ Docs 类型检查失败，请修复后重新提交。"
            exit 1
        fi
    fi

    # Docs Vitest
    if [ -n "$PNPM_RUNNER" ]; then
        echo "🧪 正在运行 Docs Vitest..."
        run_pnpm --filter docs test
        if [ $? -ne 0 ]; then
            echo "❌ Docs 测试失败，请修复后重新提交。"
            exit 1
        fi
    fi
else
    echo "⏭️  无 Docs 变更，跳过 Docs 检查。"
fi

# ── Phase 6: React Doctor（十秒级）───────────────────────

if [ "$HAS_DOCS" = true ]; then
    if [ -n "$NPX_RUNNER" ]; then
        echo "🩺 正在运行 React Doctor..."
        NO_COLOR=1 run_npx react-doctor@latest . --blocking error --no-telemetry --project docs
        if [ $? -ne 0 ]; then
            echo "❌ React Doctor 发现错误，请修复后重新提交。"
            echo "💡 运行 'pnpm doctor -- --verbose' 查看详细信息。"
            exit 1
        fi
    fi
else
    echo "⏭️  无 Docs 变更，跳过 React Doctor 检查。"
fi

# ── Phase 7: 非阻断分析 ────────────────────────────────

# Gitnexus: 更新代码索引，失败不阻断提交
if [ -n "$PNPM_RUNNER" ]; then
    run_pnpm exec gitnexus analyze || true
elif [ -n "$NPX_RUNNER" ]; then
    run_npx -y gitnexus analyze || true
else
    echo "⚠️  未找到 pnpm/npx，跳过 Gitnexus 分析。"
fi

# Gitnexus 可能更新 CLAUDE.md / AGENTS.md，自动暂存变更
CHANGED=""
for f in CLAUDE.md AGENTS.md; do
    if "$GIT_CMD" diff --name-only -- "$f" 2>/dev/null | grep -q . || \
       "$GIT_CMD" diff --cached --name-only -- "$f" 2>/dev/null | grep -q . || \
       "$GIT_CMD" ls-files --others --exclude-standard -- "$f" 2>/dev/null | grep -q .; then
        CHANGED="$CHANGED $f"
    fi
done
if [ -n "$CHANGED" ]; then
    echo "ℹ️  检测到 Gitnexus 更新了$CHANGED，正在暂存..."
    "$GIT_CMD" add $CHANGED
fi

echo "✅ 所有检查通过！"
