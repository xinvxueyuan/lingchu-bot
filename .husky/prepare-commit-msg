#!/usr/bin/env sh
# POSIX-compliant shell; invoked via .husky/_/h with `sh -e` (shebang is informational)

# 发生错误时不立即退出，允许条件分支处理 fallback
set +e

# 获取传入的参数
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# --- 跳过交互式 gitmoji 的条件检测 ---

# 条件1: $COMMIT_SOURCE 非空且非 template → 消息已通过 -m/-F/merge/squash/amend 提供
if [ -n "$COMMIT_SOURCE" ] && [ "$COMMIT_SOURCE" != "template" ]; then
    exit 0
fi

# 条件2: 提交消息文件已有用户编写的非空内容 → IDE 预填消息
FIRST_LINE=$(grep -v '^#' "$COMMIT_MSG_FILE" | grep -v '^[[:space:]]*$' | head -1)
if [ -n "$FIRST_LINE" ]; then
    exit 0
fi

# --- 尝试连接终端启动 gitmoji ---

# 尝试重定向 stdin 到 /dev/tty（git hooks 的 stdin 不连接终端）
# 如果失败说明无终端可用（IDE、CI 等），静默跳过
if ! exec < /dev/tty 2>/dev/null; then
    exit 0
fi

echo "🔧 正在启动 Gitmoji 交互界面..."

# 解析 gitmoji 调用方式：本地 devDep bin > 全局 > npx
# 输出 native:<path> | cmd:<path>（与 pre-commit 中的 resolve_js 保持一致）
GITMOJI_BIN="node_modules/.bin/gitmoji"
if [ -x "$GITMOJI_BIN" ] || [ -f "$GITMOJI_BIN.cmd" ]; then
    if printf '%s\n' "$GITMOJI_BIN" | grep -q '\.cmd$'; then
        cmd.exe /c "$GITMOJI_BIN" --hook "$COMMIT_MSG_FILE" "$COMMIT_SOURCE"
    else
        "$GITMOJI_BIN" --hook "$COMMIT_MSG_FILE" "$COMMIT_SOURCE"
    fi
    exit $?

# 2. 备选方案：尝试使用 npx 直接运行（兼容新旧版 npx）
elif command -v npx >/dev/null 2>&1; then
    # 使用 --no-install 优先尝试本地 node_modules，失败则动态下载运行
    npx gitmoji --hook "$COMMIT_MSG_FILE" "$COMMIT_SOURCE"
    exit $?

# 3. 保底方案：尝试全局安装的 gitmoji
elif command -v gitmoji >/dev/null 2>&1; then
    gitmoji --hook "$COMMIT_MSG_FILE" "$COMMIT_SOURCE"
    exit $?

# 4. 终极提示：未找到任何可用命令
else
    echo "❌ 错误: 未检测到本地 gitmoji / npx / 全局 gitmoji 命令。"
    echo "💡 请先运行 'npm install -g gitmoji-cli' 或在项目中安装 gitmoji。"
    exit 1
fi
