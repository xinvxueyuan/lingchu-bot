#!/usr/bin/env sh
# POSIX-compliant shell; invoked via .husky/_/h with `sh -e` (shebang is informational)

# Post-commit hook: Gitnexus 非阻断分析
# 在提交完成后运行 gitnexus analyze，确保索引反映最新的提交状态
# 索引更新保留在工作区，等待下次提交时包含

set +e

# ── 定位 husky 目录（兼容 symlink、subshell、不同启动路径）──────────
HUSKY_DIR=$(dirname "$0")
case "$HUSKY_DIR" in
    /*) ;;                          # 绝对路径，直接使用
    *)  HUSKY_DIR="$PWD/$HUSKY_DIR" ;; # 相对路径，补全为绝对路径
esac
HUSKY_DIR=$(cd "$HUSKY_DIR" && pwd)
LIB_DIR="$HUSKY_DIR/lib"

# ── source 库模块（获取工具解析函数）────────────────────────────────
if [ ! -f "$LIB_DIR/detect.sh" ]; then
    echo "❌ 缺少 $LIB_DIR/detect.sh，husky 模块化拆分不完整。"
    exit 1
fi
# shellcheck disable=SC1090
. "$LIB_DIR/detect.sh"

# ── 运行 Gitnexus 分析（非阻断）────────────────────────────────────
# Gitnexus 优先本地 node_modules/.bin（devDep 已装时零下载零 pnpm 开销），
# 其次 pnpm exec，最后才走 pnpm dlx 缓存
if [ -n "$GITNEXUS_RESOLVED" ]; then
    run_resolved "$GITNEXUS_RESOLVED" analyze || true
elif [ -n "$PNPM_RUNNER" ]; then
    run_pnpm exec gitnexus analyze || true
else
    echo "⚠️  未找到 gitnexus / pnpm，跳过 Gitnexus 分析。"
    exit 0
fi

# ── 检测索引文件变更，提示用户────────────────────────────────────
# Gitnexus 可能更新 CLAUDE.md / AGENTS.md，变更保留在工作区
WT_DIFF=$("$GIT_CMD" diff --name-only -- CLAUDE.md AGENTS.md 2>/dev/null)
UNTRACKED=$("$GIT_CMD" ls-files --others --exclude-standard -- CLAUDE.md AGENTS.md 2>/dev/null)
ALL_CHANGED=$(printf '%s\n%s\n' "$WT_DIFF" "$UNTRACKED" | awk 'NF' | sort -u || true)
if [ -n "$ALL_CHANGED" ]; then
    echo "ℹ️  Gitnexus 更新了 $ALL_CHANGED，索引变更已在工作区，请在下次提交时包含。"
fi
