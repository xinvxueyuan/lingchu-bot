#!/usr/bin/env bash
# Commit Message 校验: gitmoji + Conventional Commits
# 规范: https://gitmoji.dev/  |  https://www.conventionalcommits.org/

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# --- 自动追加 Signed-off-by (等效 git commit -s) ---

SIGNOFF_NAME=$(git config user.name)
SIGNOFF_EMAIL=$(git config user.email)

if [ -n "$SIGNOFF_NAME" ] && [ -n "$SIGNOFF_EMAIL" ]; then
    SIGNOFF_LINE="Signed-off-by: ${SIGNOFF_NAME} <${SIGNOFF_EMAIL}>"

    # 读取非注释行（保留空行结构）
    BODY_NO_COMMENTS=$(sed '/^#/d' "$COMMIT_MSG_FILE")

    # 边界1: 消息体为空或仅空行 → 不追加（空提交消息由后续格式校验拦截）
    if ! printf '%s' "$BODY_NO_COMMENTS" | grep -q '[^[:space:]]'; then
        COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    # 边界2: 已存在相同 Signed-off-by（精确匹配，忽略尾部空白差异）
    elif printf '%s' "$BODY_NO_COMMENTS" | sed 's/[[:space:]]*$//' | grep -qxF "$SIGNOFF_LINE"; then
        COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    else
        # 提取注释部分（保留原始顺序）
        COMMENTS=$(grep '^#' "$COMMIT_MSG_FILE" || true)

        # 去除尾部空行，保留内部结构
        BODY=$(printf '%s' "$BODY_NO_COMMENTS" | sed -e :a -e '/^\n*$/{$d;N;ba' -e '}')

        # 检测是否已有 trailer 块（以 Token: 格式结尾的段落）
        # trailer 行格式: ^[A-Za-z-]+: .+  或  ^[A-Za-z-]+ #.+（如 Fixes #123）
        LAST_NON_EMPTY=$(printf '%s' "$BODY" | grep -v '^[[:space:]]*$' | tail -1)
        HAS_TRAILER=false
        if printf '%s' "$LAST_NON_EMPTY" | grep -qE '^[A-Za-z][A-Za-z0-9_-]+[[:space:]]*(:|#)'; then
            HAS_TRAILER=true
        fi

        # 构建新消息
        {
            if [ "$HAS_TRAILER" = true ]; then
                # 已有 trailer 块 → 追加到同一块（仅一个换行分隔）
                printf '%s\n%s\n' "$BODY" "$SIGNOFF_LINE"
            else
                # 无 trailer 块 → 用空行分隔后追加
                printf '%s\n\n%s\n' "$BODY" "$SIGNOFF_LINE"
            fi
            if [ -n "$COMMENTS" ]; then
                printf '%s\n' "$COMMENTS"
            fi
        } > "$COMMIT_MSG_FILE"

        # 仅清理 trailer 区域前可能产生的多余连续空行（≥3个连续空行压缩为2个）
        # 不破坏 subject 与 body 之间、body 与 trailer 之间的单空行结构
        awk 'BEGIN{blank=0} /^[[:space:]]*$/{blank++;if(blank<=2)print;next} {blank=0;print}' "$COMMIT_MSG_FILE" > "$COMMIT_MSG_FILE.tmp" && mv "$COMMIT_MSG_FILE.tmp" "$COMMIT_MSG_FILE"

        # 重新读取更新后的消息
        COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    fi
fi

# --- 格式校验 ---

echo "🔍 正在校验 Commit Message 格式..."

# 取第一条非注释、非空行作为待校验内容(避免被 Git 自动生成的注释污染)
CLEAN_MSG=$(printf '%s\n' "$COMMIT_MSG" | grep -v '^#' | grep -v '^[[:space:]]*$' | head -1)

if [ -z "$CLEAN_MSG" ]; then
    echo "❌ 错误: 提交信息不能为空！"
    exit 1
fi

# gitmoji 官方 emoji 列表(来源: https://gitmoji.dev/)
# 包含 variation selector(️)以与 gitmoji.dev 严格对齐
GITMOJI=(
    "🎨" "⚡️" "🔥" "🐛" "🚑️" "✨" "📝" "🚀" "💄" "🎉"
    "✅" "🔒️" "🔐" "🔖" "🚨" "🚧" "💚" "⬇️" "⬆️" "📌"
    "👷" "📈" "♻️" "➕" "➖" "🔧" "🔨" "🌐" "✏️" "💩"
    "⏪️" "🔀" "📦️" "👽️" "🚚" "📄" "💥" "🍱" "♿️" "💡"
    "🍻" "💬" "🗃️" "🔊" "🔇" "👥" "🚸" "🏗️" "📱" "🤡"
    "🥚" "🙈" "📸" "⚗️" "🔍️" "🏷️" "🌱" "🚩" "🥅" "💫"
    "🗑️" "🛂" "🩹" "🧐" "⚰️" "🧪" "👔" "🩺" "🧱" "🧑‍💻"
    "💸" "🧵" "🦺" "✈️" "🦖"
)

# 拼接 emoji 模式: (🎨|⚡️|🔥|...)
EMOJI_PATTERN=$(printf "%s|" "${GITMOJI[@]}")
EMOJI_PATTERN="${EMOJI_PATTERN%|}"

# Conventional Commits 允许的 type(Angular 规范)
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# 完整正则: ^<gitmoji> <type>[!](<scope>)?[!]: <subject>
# ! = 破坏性变更标记,可出现在 type 后或 scope 后
REG_EXP="^(${EMOJI_PATTERN}) (${TYPES})(!)?(\([^\)]+\))?(!)?: .+"

if [[ ! "$CLEAN_MSG" =~ $REG_EXP ]]; then
    echo "--------------------------------------------------------"
    echo "❌ 格式错误！不符合 gitmoji + Conventional Commits 规范。"
    echo ""
    echo "💡 正确格式: <gitmoji> <type>[!](<scope>)?[!]: <subject>"
    echo "   ! = 破坏性变更标记, 可放在 type 后或 scope 后"
    echo ""
    echo "📌 常用示例:"
    echo "   ✨ feat: 新增功能"
    echo "   🐛 fix: 修复登录失败"
    echo "   📝 docs: 更新 API 文档"
    echo "   ♻️  refactor(auth): 重构鉴权模块"
    echo "   ⚡️  perf: 优化查询性能"
    echo "   💥 feat!(api): 重写接口(破坏性变更)"
    echo ""
    echo "💡 运行 'task gitmoji' 查看完整中文速查表"
    echo "🔗 在线列表: https://gitmoji.dev/"
    echo "--------------------------------------------------------"
    exit 1
fi

echo "✅ Commit Message 格式验证通过！"
