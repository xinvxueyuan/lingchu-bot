#!/usr/bin/env bash
# Commit Message 校验: gitmoji + Conventional Commits
# 规范: https://gitmoji.dev/  |  https://www.conventionalcommits.org/

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# --- 自动追加 Signed-off-by (等效 git commit -s) ---

SIGNOFF_NAME=$(git config user.name)
SIGNOFF_EMAIL=$(git config user.email)

if [ -n "$SIGNOFF_NAME" ] && [ -n "$SIGNOFF_EMAIL" ]; then
    SIGNOFF_LINE="Signed-off-by: ${SIGNOFF_NAME} <${SIGNOFF_EMAIL}>"

    # 检查是否已存在相同的 Signed-off-by 行，避免重复追加
    if ! grep -qF "$SIGNOFF_LINE" "$COMMIT_MSG_FILE"; then
        # 提取非注释内容（去除尾部空行）和注释部分
        BODY=$(sed '/^#/d' "$COMMIT_MSG_FILE" | sed -e :a -e '/^\n*$/{$d;N;ba' -e '}')
        COMMENTS=$(grep '^#' "$COMMIT_MSG_FILE" || true)

        {
            printf '%s\n\n%s\n' "$BODY" "$SIGNOFF_LINE"
            if [ -n "$COMMENTS" ]; then
                printf '%s\n' "$COMMENTS"
            fi
        } > "$COMMIT_MSG_FILE"

        # 去除多余连续空行，保持格式整洁
        sed -i '/^$/N;/^\n$/d' "$COMMIT_MSG_FILE"

        # 重新读取更新后的消息
        COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    fi
fi

# --- 格式校验 ---

echo "🔍 正在校验 Commit Message 格式..."

# 取第一条非注释、非空行作为待校验内容(避免被 Git 自动生成的注释污染)
CLEAN_MSG=$(printf '%s\n' "$COMMIT_MSG" | grep -v '^#' | grep -v '^[[:space:]]*$' | head -1)

if [ -z "$CLEAN_MSG" ]; then
    echo "❌ 错误: 提交信息不能为空！"
    exit 1
fi

# gitmoji 官方 emoji 列表(来源: https://gitmoji.dev/)
# 包含 variation selector(️)以与 gitmoji.dev 严格对齐
GITMOJI=(
    "🎨" "⚡️" "🔥" "🐛" "🚑️" "✨" "📝" "🚀" "💄" "🎉"
    "✅" "🔒️" "🔐" "🔖" "🚨" "🚧" "💚" "⬇️" "⬆️" "📌"
    "👷" "📈" "♻️" "➕" "➖" "🔧" "🔨" "🌐" "✏️" "💩"
    "⏪️" "🔀" "📦️" "👽️" "🚚" "📄" "💥" "🍱" "♿️" "💡"
    "🍻" "💬" "🗃️" "🔊" "🔇" "👥" "🚸" "🏗️" "📱" "🤡"
    "🥚" "🙈" "📸" "⚗️" "🔍️" "🏷️" "🌱" "🚩" "🥅" "💫"
    "🗑️" "🛂" "🩹" "🧐" "⚰️" "🧪" "👔" "🩺" "🧱" "🧑‍💻"
    "💸" "🧵" "🦺" "✈️" "🦖"
)

# 拼接 emoji 模式: (🎨|⚡️|🔥|...)
EMOJI_PATTERN=$(printf "%s|" "${GITMOJI[@]}")
EMOJI_PATTERN="${EMOJI_PATTERN%|}"

# Conventional Commits 允许的 type(Angular 规范)
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# 完整正则: ^<gitmoji> <type>[!](<scope>)?[!]: <subject>
# ! = 破坏性变更标记,可出现在 type 后或 scope 后
REG_EXP="^(${EMOJI_PATTERN}) (${TYPES})(!)?(\([^\)]+\))?(!)?: .+"

if [[ ! "$CLEAN_MSG" =~ $REG_EXP ]]; then
    echo "--------------------------------------------------------"
    echo "❌ 格式错误！不符合 gitmoji + Conventional Commits 规范。"
    echo ""
    echo "💡 正确格式: <gitmoji> <type>[!](<scope>)?[!]: <subject>"
    echo "   ! = 破坏性变更标记, 可放在 type 后或 scope 后"
    echo ""
    echo "📌 常用示例:"
    echo "   ✨ feat: 新增功能"
    echo "   🐛 fix: 修复登录失败"
    echo "   📝 docs: 更新 API 文档"
    echo "   ♻️  refactor(auth): 重构鉴权模块"
    echo "   ⚡️  perf: 优化查询性能"
    echo "   💥 feat!(api): 重写接口(破坏性变更)"
    echo ""
    echo "💡 运行 'task gitmoji' 查看完整中文速查表"
    echo "🔗 在线列表: https://gitmoji.dev/"
    echo "--------------------------------------------------------"
    exit 1
fi

echo "✅ Commit Message 格式验证通过！"
